# ── AudioScript Environment Variables ────────────────────────────────────────
# Copy this file to .env for local development.
# In production, set these directly in your Railway/Render dashboard.
# NEVER commit your real .env file to git.

# ── Whisper Model ─────────────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large
# Recommendation: "base" for speed, "small" or "medium" for better accuracy
MODEL_SIZE=base

# ── OpenAI API Mode (optional) ────────────────────────────────────────────────
# Set USE_OPENAI_API=true to use OpenAI's hosted Whisper API instead of
# running the model locally. This is faster to deploy (no GPU needed) but
# costs $0.006/minute of audio and sends files to OpenAI.
USE_OPENAI_API=false
OPENAI_API_KEY=

# ── File Upload Limits ────────────────────────────────────────────────────────
MAX_FILE_MB=200

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your frontend URL to restrict API access.
# Examples:
#   ALLOWED_ORIGINS=https://myapp.vercel.app
#   ALLOWED_ORIGINS=https://myapp.vercel.app,https://myapp.netlify.app
# Leave as * during development.
ALLOWED_ORIGINS=*
